{
    "manifest_version": 3,
    "name": "Motivational Quotes for New Tab",
    "version": "2.0.1",
    "author": "Akarsh T P",
    "description": "A lightning fast, zero data extension that replaces your new tab with motivational quotes. Fast, beautiful, and customizable.",
    "homepage_url": "https://github.com/akarshtp/motivational-quotes-new-tab",
    "icons": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    },
    "chrome_url_overrides": {
      "newtab": "newtab.html"
    },
    "permissions": ["storage"],
    "host_permissions": [
        "https://zenquotes.io/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "zentab-quotes@akarsh.dev",
        "strict_min_version": "142.0",
        "data_collection_permissions": {
          "required": ["none"]
        }
      }
    }
  }